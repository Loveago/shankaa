{
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://shankaa.onrender.com/api/:match*"
    },
    {
      "source": "/socket.io/:match*",
      "destination": "https://shankaa.onrender.com/socket.io/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
