# Server Configuration
PORT=5000
NODE_ENV=development

# Database (MySQL)
DATABASE_URL="mysql://username:password@localhost:3306/tsk5_db"

# JWT Secret (used for auth tokens and chat encryption fallback)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Seed (optional - if set, backend will create/update this admin at startup)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# ADMIN_PHONE=+233000000000

# Paystack Payment Gateway
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_CALLBACK_URL=https://your-domain.com/api/payment/callback

# Frontend URL (used for Paystack payment redirects and top-up callbacks)
FRONTEND_URL=https://your-frontend-domain.com

# Chat Encryption (optional — falls back to JWT_SECRET if not set)
CHAT_ENCRYPTION_KEY=your-32-char-chat-encryption-key-here
